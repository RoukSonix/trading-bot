# Trading Bot Configuration

# === Exchange API (Binance) ===
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
# For testing: use Binance Testnet
BINANCE_TESTNET=true
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret
BINANCE_ENV=testnet  # testnet or production

# === AI / LLM ===
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Discord Alerts ===
# How to get Discord Webhook URL:
# 1. Open Discord → go to your server
# 2. Right-click on channel → Edit Channel
# 3. Integrations → Webhooks → New Webhook
# 4. Copy Webhook URL and paste below
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# === Email Alerts ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL=recipient@example.com

# === Alert Settings ===
ALERTS_ENABLED=true
DISCORD_ENABLED=true
EMAIL_ENABLED=false
ALERT_ON_TRADE=true
ALERT_ON_ERROR=true
DAILY_SUMMARY_ENABLED=true
DAILY_SUMMARY_TIME=20:00

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db

# === Risk Management ===
MAX_POSITION_SIZE=100  # USDT
MAX_DAILY_LOSS=50     # USDT
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=5.0

# === Grid Settings ===
GRID_SPACING=0.5  # % between grid levels
GRID_LAYERS=10    # number of grid orders

# === Logging ===
LOG_LEVEL=INFO
