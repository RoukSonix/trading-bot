# Jesse Bot Environment Variables
# Copy to .env and fill in your values.

# ── Exchange API Keys ────────────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── Testnet / Live Mode ─────────────────────────────────────────────
# CRITICAL: Keep BINANCE_TESTNET=true unless you intentionally want real money
BINANCE_TESTNET=true
TRADING_MODE=paper

# ── Exchange Settings ────────────────────────────────────────────────
# futures or spot
JESSE_EXCHANGE_TYPE=futures
# 1 = no leverage (safest)
JESSE_LEVERAGE=1
# cross or isolated
JESSE_LEVERAGE_MODE=cross
# Starting balance for paper trading (USDT)
JESSE_STARTING_BALANCE=10000

# ── Risk Management ─────────────────────────────────────────────────
# Max position size as % of balance (default: 10%)
RISK_MAX_POSITION_PCT=10
# Max allowed daily loss as % of starting balance (default: 5%)
RISK_DAILY_LOSS_LIMIT_PCT=5
# Max drawdown from peak equity as % (default: 10%)
RISK_MAX_DRAWDOWN_PCT=10
# Path to emergency stop file (create this file to halt trading)
EMERGENCY_STOP_FILE=EMERGENCY_STOP

# ── Notifications ────────────────────────────────────────────────────
ALERTS_ENABLED=true
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI (Optional) ───────────────────────────────────────────────────
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Data ─────────────────────────────────────────────────────────────
# Optional: Custom candle data path
# JESSE_DATA_PATH=/path/to/candles
